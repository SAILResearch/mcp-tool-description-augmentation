{
  "airbnb": {
    "stdio": {
      "command": "npx",
      "args": [
        "-y", "@openbnb/mcp-server-airbnb", "--ignore-robots-txt"
      ]
    }
  },
"nationalparks": {
   "stdio": {
     "command": "npx",
     "args": [
       "-y", "mcp-server-nationalparks"
     ]
   },
   "env": {
     "NPS_API_KEY": "{{NPS_API_KEY}}"
   }
 }
  
}