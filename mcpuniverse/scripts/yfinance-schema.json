            "type": "string"
          },
          "expiration_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "option_type": {
            "type": "string",
            "enum": [
              "calls",
              "puts"
            ]
          }
        }
      },
      "output_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "contractSymbol": {
              "type": "string"
            },
            "lastTradeDate": {
              "type": [
                "string",
                "null"
              ]
            },
            "strike": {
              "type": [
                "number",
                "null"
              ]
            },
            "lastPrice": {
              "type": [
                "number",
                "null"
              ]
            },
            "bid": {
              "type": [
                "number",
                "null"
              ]
            },
            "ask": {
              "type": [
                "number",
                "null"
              ]
            },
            "change": {
              "type": [
                "number",
                "null"
              ]
            },
            "percentChange": {
              "type": [
                "number",
                "null"
              ]
            },
            "volume": {
              "type": [
                "number",
                "null"
              ]
            },
            "openInterest": {
              "type": [
                "number",
                "null"
              ]
            },
            "impliedVolatility": {
              "type": [
                "number",
                "null"
              ]
            },
            "inTheMoney": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "contractSize": {
              "type": [
                "string",
                "null"
              ]
            },
            "currency": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      }
    },
    "get_recommendations": {
      "description": "Get analyst recommendations or upgrades/downgrades for a ticker.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker",
          "recommendation_type"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          },
          "recommendation_type": {
            "type": "string",
            "enum": [
              "recommendations",
              "upgrades_downgrades"
            ]
          },
          "months_back": {
            "type": "integer",
            "minimum": 1,
            "default": 12
          }
        }
      },
      "output_schema": {
        "type": "array",
        "description": "Array of analyst recommendation or upgrade/downgrade rows.",
        "items": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
