{
  "mcp_server": "yfinance",
  "tools": {
    "get_historical_stock_prices": {
      "description": "Get historical OHLCV data for a given ticker from Yahoo Finance.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker",
          "start_date",
          "end_date"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "end_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "interval": {
            "type": "string",
            "enum": [
              "1m",
              "2m",
              "5m",
              "15m",
              "30m",
              "60m",
              "90m",
              "1h",
              "1d",
              "5d",
              "1wk",
              "1mo",
              "3mo"
            ],
            "default": "1d"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "description": "MCP execution envelope. Historical rows are returned as a JSON string under structuredContent.result.",
        "properties": {
          "meta": {
            "type": [
              "object",
              "null"
            ]
          },
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "text": {
                  "type": "string",
                  "description": "JSON string representation of the historical price rows (same shape as structuredContent.result)."
                }
              },
              "additionalProperties": true
            }
          },
          "structuredContent": {
            "type": "object",
            "required": [
              "result"
            ],
            "properties": {
              "result": {
                "type": "string",
                "description": "JSON string encoding a list of OHLCV rows. Call json.loads(result) to obtain the records described in result_schema."
              }
            },
            "additionalProperties": true
          },
          "result_schema": {
            "type": "array",
            "description": "Describes the decoded structure of structuredContent.result after json.loads.",
            "items": {
              "type": "object",
              "properties": {
                "Date": {
                  "type": "string",
                  "description": "ISO datetime"
                },
                "Open": {
                  "type": "number"
                },
                "High": {
                  "type": "number"
                },
                "Low": {
                  "type": "number"
                },
                "Close": {
                  "type": "number"
                },
                "Adj Close": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "Volume": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "Dividends": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "Stock Splits": {
                  "type": [
                    "number",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            }
          }
        },
        "required": [
          "structuredContent"
        ],
        "examples": [
          {
            "meta": null,
            "content": [
              {
                "type": "text",
                "text": "[{\"Date\":\"2025-01-08T05:00:00.000Z\",\"Open\":421.1458429196,\"High\":424.6366709819,\"Low\":419.2363524426,\"Close\":422.2398376465,\"Volume\":15054600,\"Dividends\":0.0,\"Stock Splits\":0.0}]"
              }
            ],
            "structuredContent": {
              "result": "[{\"Date\":\"2025-01-08T05:00:00.000Z\",\"Open\":421.1458429196,\"High\":424.6366709819,\"Low\":419.2363524426,\"Close\":422.2398376465,\"Volume\":15054600,\"Dividends\":0.0,\"Stock Splits\":0.0}]"
            },
            "result_schema": [
              {
                "Date": "2025-01-08T05:00:00.000Z",
                "Open": 421.1458429196,
                "High": 424.6366709819,
                "Low": 419.2363524426,
                "Close": 422.2398376465,
                "Volume": 15054600,
                "Dividends": 0.0,
                "Stock Splits": 0.0
              }
            ]
          }
        ]
      }
    },
    "get_stock_info": {
