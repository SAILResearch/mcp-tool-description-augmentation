            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "longBusinessSummary": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "fullTimeEmployees": {
            "type": [
              "integer",
              "null"
            ]
          },
          "marketCap": {
            "type": [
              "number",
              "null"
            ]
          },
          "enterpriseValue": {
            "type": [
              "number",
              "null"
            ]
          },
          "trailingPE": {
            "type": [
              "number",
              "null"
            ]
          },
          "forwardPE": {
            "type": [
              "number",
              "null"
            ]
          },
          "priceToBook": {
            "type": [
              "number",
              "null"
            ]
          },
          "dividendRate": {
            "type": [
              "number",
              "null"
            ]
          },
          "dividendYield": {
            "type": [
              "number",
              "null"
            ]
          },
          "beta": {
            "type": [
              "number",
              "null"
            ]
          },
          "fiftyTwoWeekHigh": {
            "type": [
              "number",
              "null"
            ]
          },
          "fiftyTwoWeekLow": {
            "type": [
              "number",
              "null"
            ]
          },
          "regularMarketPrice": {
            "type": [
              "number",
              "null"
            ]
          },
          "regularMarketVolume": {
            "type": [
              "number",
              "null"
            ]
          },
          "currency": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        }
      }
    },
    "get_yahoo_finance_news": {
      "description": "Fetch recent Yahoo Finance news stories for a ticker.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          }
        }
      },
      "output_schema": {
        "type": "array",
        "description": "List of news articles.",
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          }
        }
      }
    },
    "get_stock_actions": {
      "description": "Retrieve dividend and stock split history for a ticker.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          }
        }
      },
      "output_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "Date": {
              "type": "string"
            },
            "Dividends": {
              "type": [
                "number",
                "null"
              ]
            },
            "Stock Splits": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      }
    },
    "get_financial_statement": {
      "description": "Get a company's financial statement (annual or quarterly).",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker",
          "financial_type"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          },
          "financial_type": {
            "type": "string",
            "enum": [
              "income_stmt",
              "quarterly_income_stmt",
              "balance_sheet",
              "quarterly_balance_sheet",
              "cashflow",
              "quarterly_cashflow"
            ]
          }
        }
      },
      "output_schema": {
        "type": "array",
        "description": "Array of financial statement entries. Each entry corresponds to one reporting date with metrics as key-value pairs.",
        "items": {
          "type": "object",
          "required": [
            "date"
          ],
          "properties": {
            "date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "The fiscal period end date (YYYY-MM-DD)."
            }
          },
          "additionalProperties": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "examples": [
          [
            {
              "date": "2024-09-30",
              "TotalRevenue": 383285000000,
              "GrossProfit": 170782000000,
              "OperatingIncome": 119550000000,
              "NetIncome": 96772000000
            },
            {
              "date": "2023-09-30",
              "TotalRevenue": 394328000000,
              "GrossProfit": 170782000000,
              "OperatingIncome": 119550000000,
              "NetIncome": 96772000000
            }
          ]
        ]
      }
    },
    "get_holder_info": {
      "description": "Get holder or insider information for a ticker.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker",
          "holder_type"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          },
          "holder_type": {
            "type": "string",
            "enum": [
              "major_holders",
              "institutional_holders",
              "mutualfund_holders",
              "insider_transactions",
              "insider_purchases",
              "insider_roster_holders"
            ]
          }
        }
      },
      "output_schema": {
        "type": "array",
        "description": "Array of holder information rows. Fields vary depending on holder_type.",
        "items": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "get_option_expiration_dates": {
      "description": "List available option expiration dates for a ticker.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          }
        }
      },
      "output_schema": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "get_option_chain": {
      "description": "Fetch the option chain (calls or puts) for a ticker and expiration date.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker",
          "expiration_date",
          "option_type"
        ],
        "properties": {
