{
  "mcp_server": "yfinance",
  "tools": {
    "get_historical_stock_prices": {
      "description": "Get historical OHLCV data for a given ticker from Yahoo Finance.",
      "input_schema": {
        "type": "object",
        "required": [
          "ticker",
          "start_date",
          "end_date"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "end_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "interval": {
            "type": "string",
            "enum": [
              "1m",
              "2m",
              "5m",
              "15m",
              "30m",
              "60m",
              "90m",
              "1h",
              "1d",
              "5d",
              "1wk",
              "1mo",
              "3mo"
            ],
            "default": "1d"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "description": "MCP execution envelope. Historical rows are returned as a JSON string under structuredContent.result (either at the root or nested within content[].structuredContent.result).",
        "properties": {
          "meta": {
            "type": ["object", "null"]
          },
          "content": {
            "type": "array",
            "description": "Optional list of content parts; one of them may carry structuredContent with the result.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": ["string", "null"],
                  "enum": ["text", null]
                },
                "text": {
                  "type": "string",
                  "description": "JSON string representation of the historical price rows (same shape as structuredContent.result)."
                },
                "structuredContent": {
                  "type": "object",
                  "required": ["result"],
                  "properties": {
                    "result": {
                      "type": "string",
                      "description": "JSON string encoding a list of OHLCV rows. Call json.loads(result) to obtain the records described in result_schema."
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          },
          "structuredContent": {
            "type": "object",
            "description": "Container for the JSON-encoded OHLCV records returned by the MCP call. In Python this attribute is a dictionary; access values with subscription (e.g., `structured[\"result\"]`).",
            "required": ["result"],
            "properties": {
              "result": {
                "type": "string",
                "description": "JSON string encoding an array of OHLCV records.",
                "contentMediaType": "application/json",
                "contentSchema": {
                  "type": "array",
                  "description": "Parsed structure of the JSON string (after json.loads).",
                  "items": {
                    "type": "object",
                    "required": ["Date", "Close"],
                    "properties": {
                      "Date": { "type": "string", "format": "date-time" },
                      "Open": { "type": ["number", "null"] },
                      "High": { "type": ["number", "null"] },
                      "Low": { "type": ["number", "null"] },
                      "Close": { "type": ["number", "null"] },
                      "Volume": { "type": ["number", "null"] },
                      "Dividends": { "type": ["number", "null"] },
                      "Stock Splits": { "type": ["number", "null"] }
                    },
                    "additionalProperties": true
                  }
                },
                "examples": [
                  "[{\"Date\":\"2025-01-03T05:00:00.000Z\",\"Open\":418.778884609,\"High\":421.712775701,\"Low\":417.2473221952,\"Close\":421.0364990234,\"Volume\":16662900,\"Dividends\":0.0,\"Stock Splits\":0.0}]"
                ]
              }
            },
            "additionalProperties": true,
            "usage_notes": [
              "Top-level response attributes (e.g., `structuredContent`) are exposed via Python attributes on the CallToolResult, but the attribute value is a dict-like object.",
              "Retrieve the JSON payload with `structured = getattr(response, \"structuredContent\", None)` followed by `raw_result = structured[\"result\"]`."
            ]
          },
          "isError": {
            "type": ["boolean", "null"]
          },
          "result_schema": {
            "type": "array",
            "description": "Describes the decoded structure of structuredContent.result (or content[i].structuredContent.result) after json.loads.",
            "items": {
              "type": "object",
              "required": ["Date", "Close"],
              "properties": {
                "Date": {
                  "type": "string",
                  "format": "date-time",
                  "description": "ISO 8601 datetime (e.g., 2025-01-08T05:00:00.000Z)"
                },
                "Open": { "type": ["number", "null"] },
                "High": { "type": ["number", "null"] },
                "Low": { "type": ["number", "null"] },
                "Close": { "type": ["number", "null"] },
                "Volume": { "type": ["number", "null"] },
                "Dividends": { "type": ["number", "null"] },
                "Stock Splits": { "type": ["number", "null"] }
              },
              "additionalProperties": true
            }
          }
        },
        "anyOf": [
          {
            "required": ["structuredContent"],
            "properties": {
              "structuredContent": {
                "type": "object",
                "required": ["result"],
                "properties": {
                  "result": { "type": "string" }
                }
              }
            }
          },
          {
            "properties": {
              "content": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "required": ["structuredContent"],
                  "properties": {
                    "structuredContent": {
                      "type": "object",
                      "required": ["result"],
                      "properties": {
                        "result": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "examples": [
          {
            "meta": null,
            "content": [
              {
                "type": "text",
                "text": "[{\"Date\":\"2025-01-08T05:00:00.000Z\",\"Open\":421.1458429196,\"High\":424.6366709819,\"Low\":419.2363524426,\"Close\":422.2398376465,\"Volume\":15054600,\"Dividends\":0.0,\"Stock Splits\":0.0}]"
              }
            ],
            "structuredContent": {
              "result": "[{\"Date\":\"2025-01-08T05:00:00.000Z\",\"Open\":421.1458429196,\"High\":424.6366709819,\"Low\":419.2363524426,\"Close\":422.2398376465,\"Volume\":15054600,\"Dividends\":0.0,\"Stock Splits\":0.0}]"
            },
            "isError": false,
            "result_schema": [
              {
                "Date": "2025-01-08T05:00:00.000Z",
                "Open": 421.1458429196,
                "High": 424.6366709819,
                "Low": 419.2363524426,
                "Close": 422.2398376465,
                "Volume": 15054600,
                "Dividends": 0.0,
                "Stock Splits": 0.0
              }
            ]
          },
          {
            "meta": null,
            "content": [
              {
                "type": "text",
                "text": "[{\"Date\":\"2025-01-07T05:00:00.000Z\",\"Open\":426.6555708652,\"High\":428.2965477599,\"Low\":418.5003706571,\"Close\":420.0617980957,\"Volume\":18139100,\"Dividends\":0.0,\"Stock Splits\":0.0}]",
                "structuredContent": {
                  "result": "[{\"Date\":\"2025-01-07T05:00:00.000Z\",\"Open\":426.6555708652,\"High\":428.2965477599,\"Low\":418.5003706571,\"Close\":420.0617980957,\"Volume\":18139100,\"Dividends\":0.0,\"Stock Splits\":0.0}]"
                }
              }
            ],
            "isError": false
          }
        ],
        "usage_notes": "Responses are instances of CallToolResult. Access top-level fields with getattr(result, \"structuredContent\", None) or getattr(result, \"content\", None) before falling back to dictionary operations. Decode any JSON strings described above with json.loads before iterating over price rows."
      }
    },
    "get_stock_info": {
